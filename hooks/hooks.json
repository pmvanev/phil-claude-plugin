{
  "description": "Stop: Windows toast/chime notifier. PreToolUse: refactor-loop G2 test-file write-block (no-op unless a refactor-loop run is active).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/refactor-loop/block-test-file-write.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -File ${CLAUDE_PLUGIN_ROOT}/scripts/notify-stop.ps1 &"
          }
        ]
      }
    ]
  }
}
